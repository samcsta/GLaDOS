# Copy to .env on each workstation and fill in local-only values.
# Never commit .env.

GLADOS_RUNTIME_DIR=$HOME/.glados
OPENCLAW_HOME=$HOME/.openclaw

GLADOS_AGENT_WORKSPACES=$HOME/.glados/workspaces/agents
GLADOS_REPORTS_DIR=$HOME/.glados/reports
GLADOS_INVESTIGATIONS_DIR=$HOME/.glados/investigations
GLADOS_OPERATOR_CONTEXT=$HOME/.glados/operator-context.json
GLADOS_LOCAL_AUTH=$HOME/.glados/secrets/local-auth.json
BLACKBOARD_DB=$HOME/.glados/blackboard/blackboard.db
WATCHDOG_DB=$HOME/.glados/watchdog/watchdog.db

LLMAPI_BASE_URL=https://llmapi.redteamstuff.com/
LLMAPI_API_KEY=replace-me
GLADOS_PRIMARY_MODEL=custom-llmapi-redteamstuff-com/claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434/v1/

PORT=4280
BURP_PROXY=http://127.0.0.1:8080
BURP_EXT_API=http://127.0.0.1:1338
BURP_API=http://127.0.0.1:1337

OPENCLAW_AGENT_TIMEOUT_MS=1200000
OPENCLAW_RAW_STREAM=1
